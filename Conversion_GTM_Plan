<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Founding GTM for Conversion · Vijay Srinivas</title>
<meta name="description" content="A structural thesis, four pillars, fifty accounts, a ninety-day plan, and a working agent. Built from Bengaluru for Conversion's Founding GTM role.">
<meta property="og:title" content="Founding GTM for Conversion · Vijay Srinivas">
<meta property="og:description" content="A structural thesis, four pillars, fifty accounts, a ninety-day plan, and a working agent.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #FFFFFF;
    --bg-soft: #F7F7F5;
    --bg-softer: #FAFAF8;
    --ink: #0A0A0A;
    --ink-soft: #3A3A3A;
    --muted: #8A8A85;
    --line: rgba(10, 10, 10, 0.08);
    --line-strong: rgba(10, 10, 10, 0.18);

    /* Lime is the Conversion brand accent. Used for: active tab indicator,
       primary CTA hover, demo submit, upgrade markers, score-ring good state,
       Clay callout highlights, pillar-subtab active numeral. */
    --lime: #C6F547;
    --lime-dark: #9FD11F;
    --lime-soft: #E8FB9E;

    /* Rust reserved for findings/warnings/problems. Amber for mid-scores. */
    --rust: #FF5436;
    --rust-soft: #FFE5DE;
    --amber: #FF9F43;

    /* Legacy aliases, mapped to new values so existing rules still render.
       --green is now ink (structural); --green-soft is lime (accent). */
    --green: #0A0A0A;
    --green-soft: #C6F547;
    --rust-soft-border: #FF7A5B;
    --cream: #F5F5F0;
    --paper: #FAFAF8;

    --display: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;

    --max: 1240px;
    --gutter: clamp(20px, 4vw, 48px);
    --nav-h: 62px;
    --tab-h: 64px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--body);
    font-size: 16px;
    line-height: 1.55;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
    font-feature-settings: 'ss01', 'cv11';
  }

  main, nav, footer { position: relative; z-index: 2; }

  a { color: inherit; text-decoration: none; }

  /* ─── TYPOGRAPHY ─── */
  h1, h2, h3, h4, .display {
    font-family: var(--display);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.02;
    color: var(--ink);
  }

  h1 { font-size: clamp(48px, 8vw, 112px); font-weight: 700; letter-spacing: -0.045em; }
  h2 { font-size: clamp(32px, 5vw, 64px); letter-spacing: -0.035em; font-weight: 600; }
  h3 { font-size: clamp(22px, 2.6vw, 32px); letter-spacing: -0.025em; line-height: 1.15; font-weight: 600; }
  h4 { font-size: clamp(17px, 1.6vw, 20px); line-height: 1.25; font-weight: 600; letter-spacing: -0.015em; }

  .italic { font-style: italic; font-weight: inherit; }
  .mono { font-family: var(--mono); }

  p { font-size: clamp(15px, 1.05vw, 16px); line-height: 1.6; color: var(--ink-soft); }
  p.lede { font-size: clamp(18px, 1.3vw, 21px); line-height: 1.5; color: var(--ink-soft); font-weight: 400; letter-spacing: -0.01em; }

  .label {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  .label-green { color: var(--ink); }
  .label-rust { color: var(--rust); }

  /* ─── LAYOUT ─── */
  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* ─── TOP NAV ─── */
  nav.topnav {
    position: sticky;
    top: 0;
    background: rgba(242, 237, 228, 0.92);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--line);
    z-index: 100;
    height: var(--nav-h);
    display: flex;
    align-items: center;
  }

  .nav-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    width: 100%;
  }

  .nav-mark {
    font-family: var(--display);
    font-size: 19px;
    letter-spacing: -0.02em;
  }

  .nav-mark .italic { color: var(--lime-dark); }

  .nav-cta {
    padding: 9px 18px;
    background: var(--ink);
    color: var(--bg);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    transition: background 0.2s, color 0.2s;
  }

  .nav-cta:hover { background: var(--lime); color: var(--ink); }

  .nav-meta {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: none;
  }

  @media (min-width: 800px) {
    .nav-meta { display: block; }
  }

  /* ─── HERO ─── */
  .hero {
    padding: clamp(60px, 7vw, 100px) 0 clamp(48px, 6vw, 80px);
    position: relative;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
    font-size: 12px;
    color: var(--muted);
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-top .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--lime-dark);
    margin-right: 8px;
    animation: pulse 2s infinite;
    vertical-align: middle;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero h1 {
    font-size: clamp(44px, 8vw, 116px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    margin-bottom: 36px;
  }

  .hero h1 .italic {
    color: var(--lime-dark);
    display: block;
  }

  .hero-sub {
    font-size: clamp(17px, 1.35vw, 21px);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 780px;
    margin-bottom: 36px;
  }

  .hero-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 6px 14px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    font-size: 11.5px;
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .tag.filled { background: var(--ink); color: var(--bg); border-color: var(--ink); }
  .tag.green { background: var(--lime); color: var(--ink); border-color: var(--lime); }

  /* ─── TAB BAR ─── */
  .tabbar {
    position: sticky;
    top: var(--nav-h);
    background: rgba(242, 237, 228, 0.95);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    z-index: 90;
    height: var(--tab-h);
    display: flex;
    align-items: center;
  }

  .tabbar-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .tabbar-inner::-webkit-scrollbar { display: none; }

  .tabs-list {
    display: flex;
    gap: 0;
    min-width: max-content;
  }

  .tab-btn {
    appearance: none;
    background: transparent;
    border: none;
    padding: 0 18px;
    height: var(--tab-h);
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-family: var(--body);
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.2s;
    position: relative;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .tab-btn:hover { color: var(--ink); }

  .tab-btn.active { color: var(--ink); }

  .tab-btn.active::after {
    content: '';
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 0;
    height: 2px;
    background: var(--lime-dark);
  }

  .tab-btn .tab-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  .tab-btn.active .tab-num {
    color: var(--ink);
  }

  /* ─── TAB PANELS ─── */
  .panels {
    padding: clamp(48px, 6vw, 80px) 0 clamp(80px, 10vw, 120px);
  }

  .panel {
    display: none;
    animation: fadeUp 0.4s ease;
  }

  .panel.active { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── PANEL HEADERS ─── */
  .panel-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 900px) {
    .panel-head {
      grid-template-columns: 200px 1fr;
      gap: 48px;
      align-items: start;
    }
  }

  .panel-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
    padding-top: 8px;
  }

  .panel-num::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--ink);
    vertical-align: middle;
    margin-right: 10px;
    transform: translateY(-2px);
  }

  .panel-title h2 { margin-bottom: 16px; }

  .panel-lede {
    font-size: clamp(16px, 1.15vw, 19px);
    line-height: 1.5;
    color: var(--ink);
    max-width: 780px;
  }

  /* ─── THESIS PANEL ─── */
  .thesis-body { max-width: 820px; }
  .thesis-body p + p { margin-top: 20px; }
  .thesis-body p strong { color: var(--ink); font-weight: 600; }

  .thesis-quote {
    font-family: var(--display);
    font-size: clamp(24px, 3vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-style: italic;
    color: var(--ink);
    margin: 40px 0;
    padding: 0 0 0 28px;
    border-left: 3px solid var(--rust);
    max-width: 860px;
  }

  .thesis-quote cite {
    display: block;
    margin-top: 20px;
    font-size: 13px;
    font-style: normal;
    color: var(--muted);
    font-family: var(--body);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ─── COMPETITIVE MAP ─── */
  .map-wrap {
    margin-top: 56px;
    padding-top: 48px;
    border-top: 1px solid var(--line);
  }

  .map-head { margin-bottom: 32px; }

  .map-head h3 {
    font-size: clamp(24px, 2.8vw, 34px);
    margin-bottom: 12px;
  }

  .map-head p {
    max-width: 780px;
    font-size: 16px;
  }

  .comp-map {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 32px;
  }

  @media (min-width: 900px) {
    .comp-map {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }

  .camp {
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 28px 32px;
    border-radius: 4px;
  }

  .camp-legacy { border-top: 4px solid var(--rust); }
  .camp-modern { border-top: 4px solid var(--lime-dark); }

  .camp-label {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 6px;
  }

  .camp-legacy .camp-label { color: var(--rust); }
  .camp-modern .camp-label { color: var(--lime-dark); }

  .camp h3 {
    font-size: 24px;
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .camp p {
    font-size: 14.5px;
    color: var(--ink-soft);
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .camp-list {
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .camp-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    font-size: 14.5px;
  }

  .camp-list li strong { font-weight: 500; }

  .camp-list li span {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
  }

  .clay-callout {
    margin-top: 40px;
    background: var(--ink);
    color: var(--bg);
    padding: 32px;
    border-radius: 4px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 800px) {
    .clay-callout {
      grid-template-columns: 150px 1fr;
      gap: 32px;
      padding: 44px 48px;
    }
  }

  .clay-callout .label { color: rgba(242, 237, 228, 0.6); }

  .clay-callout h3 {
    color: var(--bg);
    font-size: clamp(22px, 2.2vw, 30px);
    margin: 6px 0 14px;
  }

  .clay-callout p {
    color: rgba(242, 237, 228, 0.85);
    font-size: 15px;
    line-height: 1.55;
  }

  .clay-callout .clay-mark {
    font-family: var(--display);
    font-size: 84px;
    line-height: 1;
    color: var(--lime);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  /* ─── PILLARS PANEL ─── */
  .pillar-subtabs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 800px) {
    .pillar-subtabs {
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }
  }

  .pillar-subtab {
    appearance: none;
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 18px 20px;
    text-align: left;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
    font-family: var(--body);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pillar-subtab:hover {
    border-color: var(--line-strong);
    background: var(--bg-soft);
  }

  .pillar-subtab.active {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }

  .pillar-subtab .ps-num {
    font-family: var(--display);
    font-style: italic;
    font-weight: 700;
    font-size: 26px;
    line-height: 1;
    color: var(--lime-dark);
    letter-spacing: -0.03em;
  }

  .pillar-subtab.active .ps-num { color: var(--lime); }

  .pillar-subtab .ps-label {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2px;
  }

  .pillar-subtab.active .ps-label { color: rgba(242, 237, 228, 0.6); }

  .pillar-subtab .ps-title {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--ink);
    margin-top: 2px;
  }

  .pillar-subtab.active .ps-title { color: var(--cream); }

  /* ─── PILLAR CONTENT ─── */
  .pillar-panel {
    display: none;
    animation: fadeUp 0.35s ease;
  }

  .pillar-panel.active { display: block; }

  .pillar-head-big {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 900px) {
    .pillar-head-big {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: end;
    }
  }

  .pillar-head-big h2 {
    font-size: clamp(26px, 3.4vw, 44px);
    line-height: 1.05;
  }

  .pillar-thesis-box {
    border-left: 2px solid var(--ink);
    padding: 6px 0 6px 24px;
  }

  .pillar-thesis-box p {
    font-family: var(--display);
    font-size: 19px;
    line-height: 1.35;
    color: var(--ink);
    font-style: italic;
  }

  .pillar-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 900px) {
    .pillar-body {
      grid-template-columns: 1fr 1fr;
      gap: 56px;
    }
  }

  .pillar-body h4 {
    font-size: 20px;
    margin-bottom: 14px;
    color: var(--ink);
  }

  .pillar-body p {
    font-size: 15.5px;
    margin-bottom: 14px;
    line-height: 1.55;
  }

  .pillar-body ul {
    list-style: none;
    padding: 0;
    margin-bottom: 20px;
  }

  .pillar-body ul li {
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
    padding: 10px 0 10px 26px;
    position: relative;
    border-bottom: 1px dashed var(--line);
  }

  .pillar-body ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--lime-dark);
    font-family: var(--mono);
    font-weight: 500;
  }

  .pillar-body ul li strong {
    color: var(--ink);
    font-weight: 600;
  }

  .metrics {
    margin-top: 28px;
    padding: 22px 24px;
    background: var(--bg-soft);
    border-radius: 4px;
    border: 1px solid var(--line);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 14px;
  }

  .metric-value {
    font-family: var(--display);
    font-size: 32px;
    line-height: 1;
    color: var(--lime-dark);
    letter-spacing: -0.04em;
    font-weight: 700;
  }

  .metric-label {
    font-size: 11px;
    color: var(--muted);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--mono);
  }

  .sixfront {
    margin-top: 24px;
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper);
  }

  .sixfront-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 0;
    border-bottom: 1px solid var(--line);
    padding: 14px 18px;
    font-size: 13.5px;
    align-items: start;
  }

  @media (min-width: 700px) {
    .sixfront-row {
      grid-template-columns: 110px 1fr 1fr;
      gap: 16px;
    }
  }

  .sixfront-row:last-child { border-bottom: none; }
  .sixfront-row strong { font-weight: 600; color: var(--ink); }

  .sixfront-row .comp-name {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--rust);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sixfront-row .comp-why, .sixfront-row .comp-play {
    font-size: 13.5px;
    line-height: 1.45;
  }

  .sixfront-row .comp-why { color: var(--ink-soft); }

  .sixfront-row .comp-play {
    color: var(--ink);
    font-weight: 500;
  }

  .clay-note {
    margin-top: 22px;
    padding: 14px 18px;
    background: rgba(198, 245, 71, 0.12);
    border-left: 3px solid var(--lime-dark);
    border-radius: 2px;
    font-size: 13.5px;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .clay-note strong {
    color: var(--ink);
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: var(--mono);
  }

  /* ─── ACCOUNTS PANEL ─── */
  .accounts-intro { max-width: 820px; margin-bottom: 40px; }

  .accounts-table {
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper);
  }

  .accounts-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    padding: 16px 22px;
    border-bottom: 1px solid var(--line);
    transition: background 0.2s;
  }

  @media (min-width: 800px) {
    .accounts-row {
      grid-template-columns: 150px 1fr 80px 200px;
      gap: 22px;
      align-items: center;
    }
  }

  .accounts-row:hover { background: var(--bg-soft); }
  .accounts-row:last-child { border-bottom: none; }

  .accounts-row.header {
    background: var(--ink);
