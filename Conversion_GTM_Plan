<!-- ═════════ JS ═════════ -->
<script>
  // ─────── TAB SWITCHING ───────
  const tabButtons = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.panel');

  function switchTab(tabName, event) {
    if (event) event.preventDefault();

    tabButtons.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.tab === tabName);
    });

    panels.forEach(p => {
      p.classList.toggle('active', p.id === 'panel-' + tabName);
    });

    // Update URL hash without scroll jump
    if (history.replaceState) {
      history.replaceState(null, '', '#' + tabName);
    }

    // Smooth scroll to tabbar so user sees the tab content from the top
    const tabbar = document.getElementById('tabbar');
    if (tabbar && window.scrollY > tabbar.offsetTop - 100) {
      tabbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab));
  });

  // Load tab from URL hash on page load
  window.addEventListener('DOMContentLoaded', () => {
    const hash = window.location.hash.replace('#', '');
    const validTabs = ['thesis', 'pillars', 'accounts', 'plan', 'demo', 'bengaluru'];
    if (validTabs.includes(hash)) {
      switchTab(hash);
    }
  });

  // ─────── PILLAR SUB-TABS ───────
  const pillarSubtabs = document.querySelectorAll('.pillar-subtab');
  const pillarPanels = document.querySelectorAll('.pillar-panel');

  pillarSubtabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const pillarId = btn.dataset.pillar;
      pillarSubtabs.forEach(b => b.classList.toggle('active', b === btn));
      pillarPanels.forEach(p => p.classList.toggle('active', p.id === 'pillar-' + pillarId));
    });
  });

  // ─────── DEMO LOGIC ───────
  function runHealthCheck() {
    const map = document.getElementById('f_map').value;
    const team = document.getElementById('f_team').value;
    const warehouse = document.getElementById('f_warehouse').value;
    const motion = document.getElementById('f_motion').value;
    const slack = document.getElementById('f_slack').value;
    const spend = document.getElementById('f_spend').value;

    let score = 100;
    const mapPenalty = { marketo: 22, hubspot: 16, sfmc: 26, iterable: 18, customerio: 14, hightouch: 16, none: 8 };
    score -= (mapPenalty[map] || 15);

    const hasWarehouse = warehouse !== 'none';
    if (hasWarehouse && ['marketo', 'hubspot', 'sfmc'].includes(map)) score -= 22;
    if (hasWarehouse && ['iterable', 'customerio'].includes(map)) score -= 14;
    if (!hasWarehouse) score += 5;

    if (motion === 'plg' && ['marketo', 'sfmc'].includes(map)) score -= 12;
    if (motion === 'plg' && map === 'hubspot') score -= 8;
    if (motion === 'sales' && map === 'customerio') score -= 10;

    if (slack === 'yes' && map !== 'none') score -= 8;
    if (slack === 'some') score -= 4;

    if (team === 'xl' && ['marketo', 'hubspot'].includes(map)) score -= 6;

    score = Math.max(18, Math.min(92, score));

    const mapNames = {
      marketo: 'Marketo', hubspot: 'HubSpot', sfmc: 'Salesforce Marketing Cloud',
      iterable: 'Iterable', customerio: 'Customer.io', hightouch: 'Hightouch', none: 'your current setup'
    };

    const findings = [];
    if (map === 'marketo') {
      findings.push('<strong>Adobe innovation freeze.</strong> Marketo has not shipped a foundational platform update since 2018. Your team is managing around the tool, not with it.');
      findings.push('<strong>Salesforce-only data model.</strong> Marketo flattens every enrichment into a contact field. Whatever richness you built upstream in Clay or your warehouse collapses the moment it touches your MAP.');
    }
    if (map === 'hubspot') {
      findings.push('<strong>Pricing cliff at Enterprise.</strong> HubSpot\'s upmarket push means you\'re paying $3K+ per month just to unlock custom objects, and another add-on for every real use case.');
      findings.push('<strong>No real warehouse sync.</strong> HubSpot\'s Snowflake integration maps warehouse fields onto flat contact properties. You lose event granularity the moment you sync.');
    }
    if (map === 'sfmc') {
      findings.push('<strong>B2C DNA in a B2B workflow.</strong> SFMC was built for 20M-email retail blasts. You\'re using it for 2K-account ABM, and the account hierarchy gymnastics cost you an admin full time.');
      findings.push('<strong>Einstein is not a B2B AI.</strong> The ML models trained on consumer behavior. They don\'t know what an opportunity stage means.');
    }
    if (map === 'iterable') {
      findings.push('<strong>Consumer-first cross-channel.</strong> Iterable was built for push and SMS marketing to individuals. Account-level orchestration requires workarounds that break on every schema change.');
      findings.push('<strong>No native CRM sync.</strong> The Salesforce integration is bi-directional on paper, fragile in practice. Your sales team distrusts the data.');
    }
    if (map === 'customerio') {
      findings.push('<strong>Event-triggered only, by design.</strong> Customer.io is brilliant for onboarding flows, misses entirely on ABM and long-cycle nurture.');
      findings.push('<strong>Graduation cliff is real.</strong> Every Series B PLG company hits a wall where the event-stream model can\'t represent "this champion changed companies."');
    }
    if (map === 'hightouch') {
      findings.push('<strong>You bought half a stack.</strong> Hightouch moves data. Hightouch does not run campaigns, build journeys, or orchestrate account plays. Which is why you\'re also paying for a MAP on top.');
      findings.push('<strong>Duct-tape tax.</strong> Every campaign requires coordinating Hightouch + MAP + analytics + CRM. Velocity is 3x slower than a unified platform.');
    }
    if (map === 'none') {
      findings.push('<strong>Signal scatter.</strong> Running marketing without a MAP means every campaign is a spreadsheet exercise. Attribution is fiction. Velocity is low.');
      findings.push('<strong>Scale cliff approaching.</strong> The question is which wall you hit first: the budget wall with a legacy MAP, or the capability wall with a point tool.');
    }

    if (hasWarehouse && ['marketo', 'hubspot', 'sfmc'].includes(map)) {
      findings.push('<strong>Your warehouse is smarter than your marketing team.</strong> You have ' + warehouse.charAt(0).toUpperCase() + warehouse.slice(1) + ' full of product events, revenue signals, and account-level behavioral data. Your MAP sees none of it. This is the single biggest reason Conversion exists.');
    } else if (slack === 'yes') {
      findings.push('<strong>Shared Slack channels are invisible to marketing.</strong> Your CS team lives in Slack Connect. Your marketing team is emailing into a vacuum with no idea what\'s happening in the account.');
    } else if (motion === 'plg') {
      findings.push('<strong>Product usage is not in the loop.</strong> Your PLG motion produces thousands of events per day. Your MAP sees none directly. Personalization is guesswork.');
    } else {
      findings.push('<strong>Velocity is the silent tax.</strong> Every campaign takes 2x longer than it should because the data model fights you on every custom object.');
    }

    const upgrades = [];
    upgrades.push('<strong>Warehouse-native data model.</strong> Connect ' + (hasWarehouse ? (warehouse.charAt(0).toUpperCase() + warehouse.slice(1)) : 'your future warehouse') + ' directly. Query live. No flattening. Every workflow reads real customer state.');

    if (['marketo', 'hubspot', 'sfmc'].includes(map)) {
      upgrades.push('<strong>Migration in weeks, not quarters.</strong> Our concierge ports your workflows, assets, and audiences. ' + mapNames[map] + ' to Conversion typically takes 4 to 8 weeks with one dedicated engineer.');
    } else {
      upgrades.push('<strong>One platform replaces three.</strong> Kill the point-tool patchwork. Campaigns, journeys, segmentation, forms, reporting. All in one place, reading from one data model.');
    }

    if (motion === 'plg') {
      upgrades.push('<strong>Product events as first-class citizens.</strong> Every click, feature adoption, workspace creation, and quota metric triggers workflows natively. No Hightouch middleware. Just events.');
    } else if (slack === 'yes') {
      upgrades.push('<strong>Slack Connect as a channel.</strong> Conversion workflows read Slack thread state and write back. Your marketing team finally sees what CS sees.');
    } else {
      upgrades.push('<strong>Account-level orchestration.</strong> Real ABM, with account as the atom. Not a duct tape over a lead-based system.');
    }

    upgrades.push('<strong>AI agents that actually run MarOps.</strong> Campaign creation, data analysis, personalization at scale, platform auditing. Your team reviews outputs instead of assembling them.');

    const savingsBase = {
      marketo: { low: 30, mid: 120, high: 280, xl: 550 },
      hubspot: { low: 18, mid: 70, high: 180, xl: 380 },
      sfmc: { low: 45, mid: 160, high: 340, xl: 620 },
      iterable: { low: 24, mid: 90, high: 200, xl: 420 },
      customerio: { low: 14, mid: 55, high: 140, xl: 280 },
      hightouch: { low: 22, mid: 85, high: 190, xl: 400 },
      none: { low: 0, mid: 0, high: 0, xl: 0 }
    };
    const savings = (savingsBase[map] || savingsBase.none)[spend];
    const savingsStr = savings === 0 ? 'N/A' : '$' + savings + 'K';

    let complexity = 'Medium';
    if (map === 'sfmc' || map === 'marketo') complexity = (team === 'xl' ? 'High' : 'Med-High');
    if (map === 'customerio' || map === 'none') complexity = 'Low';
    if (map === 'hubspot') complexity = 'Medium';
    if (map === 'hightouch') complexity = 'Low-Med';

    let timeline = '4-8 weeks';
    if (complexity === 'High') timeline = '10-14 weeks';
    if (complexity === 'Med-High') timeline = '8-12 weeks';
    if (complexity === 'Medium') timeline = '6-10 weeks';
    if (complexity === 'Low-Med') timeline = '4-6 weeks';
    if (complexity === 'Low') timeline = '2-4 weeks';

    let verdictHeader = '';
    let verdictBody = '';
    if (score >= 75) {
      verdictHeader = 'You\'re in a decent spot, but leaving upside on the table.';
      verdictBody = 'Your stack isn\'t broken. It\'s just not doing the work modern B2B marketing requires. A move to Conversion is offense, not defense.';
    } else if (score >= 55) {
      verdictHeader = 'The cracks are visible. You know it.';
      verdictBody = 'You\'re probably aware your current MAP is under-serving the business. The question isn\'t whether to switch, it\'s when the pain crosses the switching cost.';
    } else {
      verdictHeader = 'You\'re paying a tax every day you stay.';
      verdictBody = 'Your stack is actively limiting your marketing team. Every quarter on the current MAP is a quarter of compounding loss.';
    }

    const resultDiv = document.getElementById('demoResult');
    resultDiv.classList.add('visible');

    animateNumber(document.getElementById('scoreNum'), 0, score, 1200);

    const circumference = 339.29;
    const offset = circumference - (score / 100) * circumference;
    const ring = document.getElementById('ringFill');

    let ringColor = '#9FD11F';
    if (score < 40) ringColor = '#FF5436';
    else if (score < 65) ringColor = '#FF9F43';
    ring.setAttribute('stroke', ringColor);

    setTimeout(() => ring.setAttribute('stroke-dashoffset', offset), 100);

    document.getElementById('verdictHeader').textContent = verdictHeader;
    document.getElementById('verdictBody').textContent = verdictBody;

    const findingsList = document.getElementById('findingsList');
    findingsList.innerHTML = '';
    findings.slice(0, 3).forEach(f => {
      const li = document.createElement('li');
      li.innerHTML = f;
      findingsList.appendChild(li);
    });

    const upgradesList = document.getElementById('upgradesList');
    upgradesList.innerHTML = '';
    upgrades.slice(0, 3).forEach(u => {
      const li = document.createElement('li');
      li.innerHTML = u;
      upgradesList.appendChild(li);
    });

    document.getElementById('stat-savings').textContent = savingsStr;
    document.getElementById('stat-complexity').textContent = complexity;
    document.getElementById('stat-timeline').textContent = timeline;

    setTimeout(() => {
      document.getElementById('demoResult').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 200);
  }

  function animateNumber(el, from, to, duration) {
    const start = performance.now();
    function step(now) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = Math.round(from + (to - from) * eased);
      el.textContent = value;
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
</script>

