<!-- TOP BAR -->
<div class="top-bar">
  <div class="logo">Lucio<span>.</span>ai <span style="color: var(--gray); font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 400;">× Seward & Kissel</span></div>
